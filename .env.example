# Kopiere diese Datei zu ".env" und passe die Werte an.
# ".env" selbst gehört NICHT ins Git-Repo (siehe .gitignore) - genau
# das ist der Punkt: Secrets bleiben lokal, nicht im Code.

POSTGRES_USER=mailbox_user
POSTGRES_PASSWORD=change_me_locally

# 256-bit Key, Base64-kodiert, für die AES-256-GCM Nachrichtenverschlüsselung.
# Neu generieren mit:
#   openssl rand -base64 32
APP_ENCRYPTION_MASTER_KEY_BASE64=

# Mindestens 256-bit Key, Base64-kodiert, zum Signieren der JWT Access-Tokens.
# Neu generieren mit:
#   openssl rand -base64 64
APP_JWT_SECRET_BASE64=
